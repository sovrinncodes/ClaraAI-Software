generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TENANT_ADMIN
  FACILITY_MANAGER
  READ_ONLY
}

// Platform-level staff roles (CPT internal) — separate from tenant UserRole.
// Null platformRole = ordinary tenant user with no staff access.
enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  ANALYST
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum FacilityType {
  DATA_CENTER
  MANUFACTURING
  COMMERCIAL
  LOGISTICS
  AGRICULTURE
}

enum FacilityStatus {
  OPTIMAL
  WATCH
  ADVISORY
  CRITICAL
}

enum AssetType {
  CRAC_UNIT
  CRAH_UNIT
  CHILLER
  COOLING_TOWER
  PUMP
  UPS
  PDU
  AHU
  FAN
  COMPRESSOR
  MOTOR
  GENERATOR
  CONVEYOR
}

enum AlertSeverity {
  CRITICAL
  ADVISORY
  WATCH
  INFO
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  FALSE_POSITIVE
}

enum ReportFramework {
  GRI_302
  GRI_303
  GRI_305
  GHG_PROTOCOL
  ISO_50001
  TCFD
  GRESB
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  industry  String
  plan      String       @default("trial")
  status    TenantStatus @default(ACTIVE)
  isDemo    Boolean      @default(false)
  logoUrl   String?
  metadata  Json? // staff-managed settings, e.g. { featureFlags: { acousticMonitor, hotSpotTracker } }
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users      User[]
  facilities Facility[]
  assets     Asset[]
  alerts     Alert[]
  esgReports EsgReport[]
  esgScores  EsgScore[]
  waterUsage WaterUsage[]

  @@map("tenants")
}

model User {
  id           String        @id @default(cuid())
  tenantId     String
  email        String        @unique
  name         String?
  role         UserRole      @default(FACILITY_MANAGER)
  platformRole PlatformRole?
  isDisabled   Boolean       @default(false)
  cognitoSub   String        @unique
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("users")
}

model Facility {
  id             String         @id @default(cuid())
  tenantId       String
  externalId     String
  name           String
  type           FacilityType
  status         FacilityStatus @default(OPTIMAL)
  city           String
  region         String
  country        String         @default("ZA")
  totalAreaSqm   Float?
  tierRating     String?
  gridZone       String?
  managerName    String?
  commissionedAt DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  assets          Asset[]
  alerts          Alert[]
  esgReports      EsgReport[]
  esgScores       EsgScore[]
  waterUsage      WaterUsage[]
  energyBaselines EnergyBaseline[]

  @@index([tenantId])
  @@map("facilities")
}

model Asset {
  id                 String    @id @default(cuid())
  tenantId           String
  facilityId         String
  externalId         String
  name               String
  type               AssetType
  manufacturer       String?
  model              String?
  serialNumber       String?
  capacity           Float?
  capacityUnit       String?
  refrigerant        String?
  commissionedAt     DateTime?
  lastServicedAt     DateTime?
  locationInFacility String?
  isCritical         Boolean   @default(false)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  facility     Facility      @relation(fields: [facilityId], references: [id])
  healthScores HealthScore[]
  alerts       Alert[]

  @@index([tenantId])
  @@index([facilityId])
  @@map("assets")
}

model HealthScore {
  id               String   @id @default(cuid())
  tenantId         String
  assetId          String
  score            Float
  predictedTtfDays Float?
  faultType        String?
  faultConfidence  Float?
  vibrationRms     Float?
  operatingLoad    Float?
  isoZone          String?
  modelVersion     String?
  recordedAt       DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([assetId])
  @@index([recordedAt])
  @@map("health_scores")
}

model Alert {
  id               String        @id @default(cuid())
  tenantId         String
  facilityId       String
  assetId          String?
  severity         AlertSeverity
  status           AlertStatus   @default(ACTIVE)
  modelName        String
  title            String
  description      String
  recommendation   String?
  predictedTtfDays Float?
  deviationPct     Float?
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])
  asset    Asset?   @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([facilityId])
  @@index([status])
  @@index([createdAt])
  @@map("alerts")
}

model EnergyBaseline {
  id           String   @id @default(cuid())
  tenantId     String
  facilityId   String
  periodStart  DateTime
  periodEnd    DateTime
  intervalMin  Int      @default(15)
  baselineKwh  Float
  actualKwh    Float
  deviationPct Float
  anomalyFlag  Boolean  @default(false)
  recordedAt   DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([tenantId])
  @@index([facilityId])
  @@index([recordedAt])
  @@map("energy_baselines")
}

model EsgReport {
  id              String          @id @default(cuid())
  tenantId        String
  facilityId      String
  framework       ReportFramework
  periodStart     DateTime
  periodEnd       DateTime
  totalKwh        Float
  scope1Tco2e     Float
  scope2Tco2e     Float
  scope3Tco2e     Float?
  pueAverage      Float?
  dataCompletePct Float
  generatedAt     DateTime        @default(now())
  pdfUrl          String?
  reportName      String?
  status          String          @default("ready") // ready | generating | failed
  payload         Json? // full structured framework output

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([tenantId])
  @@index([facilityId])
  @@index([generatedAt])
  @@map("esg_reports")
}

// Composite ESG score — computed and persisted periodically
model EsgScore {
  id                String   @id @default(cuid())
  tenantId          String
  facilityId        String? // null = portfolio-level aggregate
  compositeScore    Float // 0-100
  energyDimScore       Float
  carbonDimScore       Float
  equipmentDimScore    Float    @default(0)
  renewableDimScore    Float
  waterDimScore        Float
  reportingDimScore    Float
  scope1Tco2e       Float?
  scope2Tco2e       Float?
  scope3Tco2e       Float?
  renewablePct      Float?
  pueAverage        Float?
  totalKwh          Float?
  recordedAt        DateTime @default(now())
  periodStart       DateTime
  periodEnd         DateTime

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([tenantId])
  @@index([facilityId])
  @@index([recordedAt])
  @@map("esg_scores")
}

// Water consumption per facility per period
model WaterUsage {
  id          String   @id @default(cuid())
  tenantId    String
  facilityId  String
  usageKl     Float // kilolitres consumed
  wue         Float? // Water Usage Effectiveness (L/kWh IT load)
  source      String   @default("municipal") // municipal | borehole | recycled | mixed
  periodStart DateTime
  periodEnd   DateTime
  recordedAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([tenantId])
  @@index([facilityId])
  @@index([recordedAt])
  @@map("water_usage")
}

// Platform staff activity log — every admin mutation and impersonation
// start/stop writes a row. Not tenant-scoped: staff-only surface.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String // staff user id ('synthetic' in demo mode)
  actorEmail String
  action     String // 'IMPERSONATE_START' | 'IMPERSONATE_END' | 'TENANT_RESEED' | 'TENANT_STATUS_CHANGE' | ...
  targetType String // 'TENANT' | 'USER' | 'ASSET' | ...
  targetId   String
  tenantId   String? // affected tenant, when applicable
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}
